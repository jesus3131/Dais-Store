# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=poner_un_secreto_fuerte_aqui

# Credenciales del admin principal (se sincronizan a DB al iniciar)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambiar_esta_contraseña

# Puertos
PORT=4000

# Orígenes CORS (separados por coma). Ej: https://midominio.com,https://admin.midominio.com
# Si se deja vacío, solo localhost:5173 y localhost:4000
CORS_ORIGINS=

# Base de datos local (Postgres)
DB_HOST=127.0.0.1
DB_PORT=8001
DB_USER=postgres
DB_PASSWORD=tu_contraseña_db
DB_NAME=dais_store
